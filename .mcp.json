{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/rkqksk/projects/new_rag"],
      "description": "File system access (always available)"
    },

    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "/home/rkqksk/projects/new_rag"],
      "description": "Git repository operations and code search (official Python-based)"
    },

    "qdrant": {
      "command": "python3",
      "args": ["-m", "mcp_servers.qdrant_server"],
      "env": {"PYTHONPATH": "${PWD}"},
      "description": "Qdrant vector database (project-specific)"
    },

    "ollama": {
      "command": "python3",
      "args": ["-m", "mcp_servers.ollama_server"],
      "env": {
        "PYTHONPATH": "${PWD}",
        "OLLAMA_HOST": "${OLLAMA_HOST:-localhost}",
        "OLLAMA_PORT": "${OLLAMA_PORT:-11434}",
        "OLLAMA_DEFAULT_MODEL": "qwen2.5:7b-instruct"
      },
      "description": "Ollama LLM server (quality inference)"
    },

    "rag-orchestrator": {
      "command": "python3",
      "args": ["-m", "mcp_servers.rag_orchestrator"],
      "env": {"PYTHONPATH": "${PWD}"},
      "description": "RAG pipeline orchestrator"
    },

    "query-router": {
      "command": "python3",
      "args": ["-m", "mcp_servers.query_router"],
      "env": {
        "PYTHONPATH": "${PWD}",
        "MODEL_ROUTER_SIMPLE_THRESHOLD": "${MODEL_ROUTER_SIMPLE_THRESHOLD:-0.3}",
        "MODEL_ROUTER_COMPLEX_THRESHOLD": "${MODEL_ROUTER_COMPLEX_THRESHOLD:-0.7}"
      },
      "description": "Query router (NexaAI/Ollama selection)"
    },

    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "description": "Browser automation (heavy - load on-demand only)"
    },

    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/test"],
      "description": "Advanced browser automation (heavy - load on-demand only)"
    },

    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "description": "HTTP requests (lightweight)"
    },

    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "description": "Chrome DevTools (specialized - load on-demand)"
    },

    "shadcn-ui": {
      "command": "npx",
      "args": ["-y", "@jpisnice/shadcn-ui-mcp-server"],
      "description": "shadcn/ui components (React, Svelte, Vue, React Native)"
    },

    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {"GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"},
      "description": "GitHub API (free for public repos)"
    },

    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://postgres:postgres@localhost:15432/rag_enterprise"],
      "description": "PostgreSQL production database"
    },

    "sqlite": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db-path", "/home/rkqksk/projects/new_rag/data/cache.db"],
      "description": "SQLite caching database"
    },

    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {"TAVILY_API_KEY": "${TAVILY_API_KEY}"},
      "description": "AI web search with real-time data, extract, map & crawl",
      "note": "Optional - https://tavily.com - Get API key from https://app.tavily.com"
    }
  },

  "metadata": {
    "version": "3.1.1",
    "updated": "2025-11-15",
    "pattern": "progressive-disclosure",
    "description": "Unified MCP registry - agents discover and load tools on-demand for 98.7% token reduction",
    "total_servers": 15,
    "core_servers": ["filesystem", "git", "qdrant", "ollama", "rag-orchestrator", "query-router"],
    "on_demand_servers": ["puppeteer", "playwright", "chrome-devtools", "shadcn-ui", "github", "postgres", "sqlite"],
    "lightweight_servers": ["fetch"],
    "optional_servers": ["tavily"],
    "status": "All servers verified and working (2025-11-15)",
    "token_strategy": {
      "pattern": "progressive-disclosure",
      "reduction": "98.7%",
      "approach": "Agents explore on-demand, load only needed tools, process data locally"
    }
  }
}
