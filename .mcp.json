{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/oypnus/Project/rag-enterprise"
      ]
    },
    "claude_api": {
      "command": "python",
      "args": ["-m", "mcp_servers.claude_api_server"],
      "description": "Unified Claude API server (Haiku 4.5 + Sonnet 4.5)"
    },
    "chrome_devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "description": "Official Google Chrome DevTools MCP for browser automation"
    },
    "qdrant": {
      "command": "python",
      "args": ["-m", "mcp_servers.qdrant_server"]
    },
    "ollama": {
      "command": "python",
      "args": ["-m", "mcp_servers.ollama_server"]
    }
  }
}
