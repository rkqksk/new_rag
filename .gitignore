# ============================================
# RAG Enterprise .gitignore
# ============================================

# ============================================
# Environment & Secrets
# ============================================
.env
.env.local
.env.*.local
.envrc.local
*.secret
*.key

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================
# Node.js
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# IDE / Editors
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.cursor/

# ============================================
# Claude Code & AI Tools
# ============================================
.claude/
.checkpoints/
.mcp.profile.current
.mcp.json

# ============================================
# Database & Data
# ============================================
*.sqlite3
*.db
/documents/
/images/

# ============================================
# DATA FOLDER - COMPLETE IGNORE
# ============================================
# Ignore EVERYTHING in /data/ folder except specific whitelist
/data/*

# Whitelist: Only allow specific documentation files
!/data/.gitkeep
!/data/**/.gitkeep
!/data/*.md
!/data/**/*.md
!/data/sample_requests.json
!/data/product_dictionary_structure.json

# Crawler data directories (explicitly ignored)
/data/onehago/
/data/freemold/
/data/chungjinkorea/
/data/chunjinkorea/
/data/crawled_products/
/data/crawled_products_final/
/data/crawled_products_organized/
/data/excel_uploads/

# Database directories
/data/qdrant/
/data/redis/
/data/postgres/
/data/mongodb/
/data/n8n/
/data/ollama/
/data/prometheus/
/data/grafana/

# Additional safeguards for large files
*.tar.gz
*.tar
*.zip
*.backup
*.bak
*.xlsx
*.xls

# Media files
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.pdf

# ============================================
# ML Models & Checkpoints
# ============================================
models/
checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.onnx

# ============================================
# Logs & Reports
# ============================================
*.log
logs/
*.out
*_REPORT.md
*_DEBUGGING_*.md
*_results.json
benchmark_*.json

# ============================================
# Docker
# ============================================
docker-compose.override.yml

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.bak
*.cache

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Testing
# ============================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ============================================
# Development
# ============================================
dev/experiments/
dev/prototypes/
dev/sandbox/
dev/notebooks/

# ============================================
# Browser Drivers & ChromeDriver
# ============================================
.direnv/python-*/bin/chromedriver
.direnv/python-*/bin/chromedriver.*
chromedriver
chromedriver.*
/chromedriver*

# ============================================
# Claude Code Generated
# ============================================
claudedocs/
claude-code/

# ============================================
# Archives
# ============================================
archives/*
!archives/.gitkeep

# ============================================
# Temporary
# ============================================
temp/
*.tmp

# ============================================
# User-specific
# ============================================
!.env.example
