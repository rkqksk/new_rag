# ============================================
# RAG Enterprise .gitignore
# ============================================

# ============================================
# Environment & Secrets
# ============================================
.env
.env.local
.env.*.local
.envrc.local
*.secret
*.key

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================
# Node.js
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# IDE / Editors
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.cursor/

# ============================================
# Claude Code & AI Tools
# ============================================
.claude/
.checkpoints/

# ============================================
# Database & Data
# ============================================
*.sqlite3
*.db
/documents/
/images/
/data/qdrant/
/data/redis/
/data/postgres/
/data/mongodb/
/data/n8n/
/data/ollama/
/data/prometheus/
/data/grafana/
/data/crawled_products_organized/
/data/crawled_products/
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.pdf

# ============================================
# ML Models & Checkpoints
# ============================================
models/
checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.onnx

# ============================================
# Logs & Reports
# ============================================
*.log
logs/
*.out
*_REPORT.md
*_DEBUGGING_*.md
*_results.json
benchmark_*.json

# ============================================
# Docker
# ============================================
docker-compose.override.yml

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.bak
*.cache

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Testing
# ============================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ============================================
# Development
# ============================================
dev/experiments/
dev/prototypes/
dev/sandbox/
dev/notebooks/

# ============================================
# Claude Code Generated
# ============================================
claudedocs/
claude-code/

# ============================================
# Archives
# ============================================
archives/*
!archives/.gitkeep

# ============================================
# Temporary
# ============================================
temp/
*.tmp

# ============================================
# User-specific
# ============================================
!.env.example
