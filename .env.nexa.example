# NexaAI SDK Configuration
# Copy this to .env and customize

# ============================================================================
# NexaAI Settings
# ============================================================================

# Enable NexaAI engine
NEXA_ENABLED=true

# NexaAI server URL (started with: nexa serve --host 0.0.0.0:8080)
NEXA_BASE_URL=http://localhost:8080/v1

# Default models
NEXA_DEFAULT_MODEL=Qwen3-1.7B
NEXA_VISION_MODEL=Qwen3-VL-4B-Instruct
NEXA_EMBEDDING_MODEL=EmbeddingGemma

# ============================================================================
# Model Router Configuration
# ============================================================================

# Enable intelligent model routing
MODEL_ROUTER_ENABLED=true

# Complexity thresholds (0.0 - 1.0)
MODEL_ROUTER_SIMPLE_THRESHOLD=0.3    # Below this → simple model (NexaAI Qwen3-1.7B)
MODEL_ROUTER_COMPLEX_THRESHOLD=0.7   # Above this → complex model (Ollama qwen2.5:7b)

# ============================================================================
# Engine Availability
# ============================================================================

# Enable/disable specific engines
ENABLE_NEXA=true
ENABLE_OLLAMA=true

# ============================================================================
# Ollama Settings (Existing)
# ============================================================================

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# ============================================================================
# Qdrant Settings (Existing)
# ============================================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=products_atomic

# ============================================================================
# Redis Settings (Existing)
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================================
# PostgreSQL Settings (Existing)
# ============================================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag123

# ============================================================================
# API Settings
# ============================================================================

API_HOST=0.0.0.0
API_PORT=8001
DEBUG=true

# ============================================================================
# Cloudflare Settings (for deployment)
# ============================================================================

# Cloudflare Workers
CF_ACCOUNT_ID=your-account-id
CF_API_TOKEN=your-api-token

# Cloudflare Vectorize
CF_VECTORIZE_INDEX=rag-products

# Cloudflare D1
CF_D1_DATABASE=rag-metadata

# Cloudflare KV
CF_KV_NAMESPACE=rag-cache
