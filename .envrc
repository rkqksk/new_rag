# RAG Enterprise direnv Configuration

# Python version and virtual environment
use python3.11
layout python

# Upgrade pip and setuptools
pip install --upgrade pip setuptools wheel

# Install project dependencies
pip install -r requirements.txt

# Development tools
pip install black isort mypy pytest pytest-cov

# Environment variables
export PYTHONPATH=.
export RAG_ENV=development

# Optional: Add project-specific environment configurations
export RAG_PROJECT_ROOT="$PWD"

# Deactivate on leaving directory (optional safety measure)
if [[ "${RAG_DIRENV_UNLOAD:-0}" == "1" ]]; then
    deactivate
fi