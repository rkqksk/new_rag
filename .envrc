# ============================================
# MCP 프로필 자동 전환
# ============================================
# 사용법: .envrc에서 MCP_PROFILE을 변경하면 자동으로 프로필 전환
#   - max: 전체 기능 (7개 서버, ~2100 tokens)
#   - api: 경량 버전 (4개 서버, ~1200 tokens)
export MCP_PROFILE="${MCP_PROFILE:-max}"  # 기본값: max

# 프로필 자동 전환 로직
_switch_mcp_profile() {
    local current_profile="$MCP_PROFILE"
    local marker_file=".mcp.profile.current"
    local previous_profile=""

    # 이전 프로필 읽기
    if [ -f "$marker_file" ]; then
        previous_profile=$(cat "$marker_file")
    fi

    # 프로필 변경 감지
    if [ "$current_profile" != "$previous_profile" ]; then
        echo "🔄 MCP Profile: $previous_profile → $current_profile"

        # 프로필 전환 스크립트 실행
        if [ -f "./scripts/switch_mcp_profile.sh" ]; then
            bash ./scripts/switch_mcp_profile.sh "$current_profile" 2>/dev/null
            echo "$current_profile" > "$marker_file"
            echo "✅ MCP profile switched to: $current_profile"
            echo "⚠️  Restart Claude Code to apply changes"
        else
            echo "⚠️  Profile switch script not found"
        fi
    fi
}

# direnv 로드 시 자동 전환
_switch_mcp_profile
