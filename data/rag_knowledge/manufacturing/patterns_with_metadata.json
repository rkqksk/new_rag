{
  "metadata": {
    "source": "plugins/manufacturing_expert/config",
    "plugin": "manufacturing_expert",
    "data_type": "patterns",
    "format": "json",
    "created_from": "yaml_config",
    "purpose": "rag_indexing",
    "searchable": true,
    "domain": "manufacturing",
    "total_entries": 8
  },
  "data": {
    "parameters": {
      "temperature": {
        "patterns": [
          "temp(?:erature)?\\s*[=:]\\s*([\\d.-]+)\\s*°?([CF])?",
          "([\\d.-]+)\\s*°([CF])"
        ],
        "unit_conversion": {
          "C": "celsius",
          "F": "fahrenheit"
        }
      },
      "pressure": {
        "patterns": [
          "pressure\\s*[=:]\\s*([\\d.-]+)\\s*(psi|bar|kpa|mpa|pascal)?",
          "([\\d.-]+)\\s*(psi|bar|kpa)"
        ],
        "unit_conversion": {
          "psi": "pounds_per_square_inch",
          "bar": "bar",
          "kpa": "kilopascal",
          "mpa": "megapascal"
        }
      },
      "time": {
        "patterns": [
          "(?:time|duration)\\s*[=:]\\s*([\\d.-]+)\\s*(min|hr|sec|hours?|minutes?|seconds?)?",
          "([\\d.-]+)\\s*(min|hr|sec)"
        ],
        "unit_conversion": {
          "min": "minutes",
          "hr": "hours",
          "sec": "seconds"
        }
      },
      "speed": {
        "patterns": [
          "speed\\s*[=:]\\s*([\\d.-]+)\\s*(rpm|m/s|ft/min)?",
          "([\\d.-]+)\\s*rpm"
        ],
        "unit_conversion": {
          "rpm": "revolutions_per_minute",
          "m/s": "meters_per_second",
          "ft/min": "feet_per_minute"
        }
      },
      "flow_rate": {
        "patterns": [
          "flow\\s*(?:rate)?\\s*[=:]\\s*([\\d.-]+)\\s*(l/min|gpm|cfm)?"
        ],
        "unit_conversion": {
          "l/min": "liters_per_minute",
          "gpm": "gallons_per_minute",
          "cfm": "cubic_feet_per_minute"
        }
      },
      "dimension": {
        "patterns": [
          "(?:length|width|height|diameter)\\s*[=:]\\s*([\\d.-]+)\\s*(mm|cm|m|inch|in|ft)?",
          "([\\d.-]+)\\s*(mm|cm|m|inch|in)"
        ],
        "unit_conversion": {
          "mm": "millimeter",
          "cm": "centimeter",
          "m": "meter",
          "inch": "inch",
          "in": "inch",
          "ft": "foot"
        }
      }
    },
    "quality_metrics": {
      "cpk": {
        "patterns": [
          "cpk\\s*[=:]\\s*([\\d.]+)",
          "process\\s*capability\\s*index\\s*[=:]\\s*([\\d.]+)"
        ],
        "threshold": {
          "excellent": 2.0,
          "acceptable": 1.33,
          "marginal": 1.0
        }
      },
      "oee": {
        "patterns": [
          "oee\\s*[=:]\\s*([\\d.]+)%?",
          "overall\\s*equipment\\s*effectiveness\\s*[=:]\\s*([\\d.]+)%?"
        ],
        "threshold": {
          "world_class": 85,
          "good": 70,
          "acceptable": 60
        }
      },
      "yield": {
        "patterns": [
          "(?:yield|fpy|first\\s*pass\\s*yield)\\s*[=:]\\s*([\\d.]+)%?"
        ],
        "threshold": {
          "excellent": 99,
          "good": 95,
          "acceptable": 90
        }
      },
      "defect_rate": {
        "patterns": [
          "(?:defect\\s*rate|ppm|dpmo)\\s*[=:]\\s*([\\d.]+)"
        ],
        "threshold": {
          "six_sigma": 3.4,
          "excellent": 100,
          "acceptable": 1000
        }
      }
    },
    "equipment_specs": {
      "power": {
        "patterns": [
          "power\\s*[=:]\\s*([\\d.]+)\\s*(w|kw|mw|hp)?",
          "([\\d.]+)\\s*(kw|hp)"
        ],
        "unit_conversion": {
          "w": "watt",
          "kw": "kilowatt",
          "mw": "megawatt",
          "hp": "horsepower"
        }
      },
      "voltage": {
        "patterns": [
          "voltage\\s*[=:]\\s*([\\d.]+)\\s*v(?:ac|dc)?",
          "([\\d.]+)\\s*v(?:ac|dc)?"
        ]
      },
      "capacity": {
        "patterns": [
          "capacity\\s*[=:]\\s*([\\d.]+)\\s*(units?/hr|pcs?/hr|kg/hr)?"
        ]
      },
      "cycle_time": {
        "patterns": [
          "cycle\\s*time\\s*[=:]\\s*([\\d.]+)\\s*(sec|min)?"
        ]
      }
    },
    "tolerances": {
      "plus_minus": {
        "patterns": [
          "([\\d.]+)\\s*±\\s*([\\d.]+)",
          "([\\d.]+)\\s*\\+/-\\s*([\\d.]+)"
        ]
      },
      "range": {
        "patterns": [
          "([\\d.]+)\\s*-\\s*([\\d.]+)",
          "between\\s*([\\d.]+)\\s*and\\s*([\\d.]+)",
          "from\\s*([\\d.]+)\\s*to\\s*([\\d.]+)"
        ]
      },
      "min_max": {
        "patterns": [
          "min(?:imum)?\\s*[=:]\\s*([\\d.]+)",
          "max(?:imum)?\\s*[=:]\\s*([\\d.]+)"
        ]
      }
    },
    "safety": {
      "hazard_keywords": [
        "danger",
        "warning",
        "caution",
        "hazard",
        "risk",
        "toxic",
        "flammable",
        "corrosive",
        "explosive"
      ],
      "ppe_requirements": [
        "safety glasses",
        "gloves",
        "hard hat",
        "respirator",
        "ear protection",
        "safety shoes"
      ],
      "lockout_tagout": {
        "patterns": [
          "loto",
          "lockout.*tagout",
          "energy isolation"
        ]
      }
    },
    "standards": {
      "iso": {
        "patterns": [
          "iso\\s*([0-9]+)",
          "iso\\s*([0-9]+:[0-9]+)"
        ]
      },
      "astm": {
        "patterns": [
          "astm\\s*([A-Z][0-9]+)"
        ]
      },
      "ansi": {
        "patterns": [
          "ansi\\s*([A-Z0-9.-]+)"
        ]
      }
    },
    "temporal": {
      "date": {
        "patterns": [
          "([0-9]{1,2})/([0-9]{1,2})/([0-9]{2,4})",
          "([0-9]{4})-([0-9]{2})-([0-9]{2})",
          "([A-Za-z]+)\\s+([0-9]{1,2}),?\\s+([0-9]{4})"
        ]
      },
      "time": {
        "patterns": [
          "([0-9]{1,2}):([0-9]{2})(?::([0-9]{2}))?\\s*(am|pm)?"
        ]
      }
    },
    "identifiers": {
      "batch_number": {
        "patterns": [
          "batch\\s*(?:number|#):?\\s*([A-Z0-9-]+)",
          "lot\\s*(?:number|#):?\\s*([A-Z0-9-]+)"
        ]
      },
      "serial_number": {
        "patterns": [
          "s/n:?\\s*([A-Z0-9-]+)",
          "serial\\s*(?:number|#):?\\s*([A-Z0-9-]+)"
        ]
      },
      "part_number": {
        "patterns": [
          "p/n:?\\s*([A-Z0-9-]+)",
          "part\\s*(?:number|#):?\\s*([A-Z0-9-]+)"
        ]
      }
    }
  }
}