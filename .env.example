# RAG Enterprise Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Database Credentials
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=rag_enterprise

# ============================================
# N8N Workflow Automation
# ============================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_USER=admin
N8N_PASSWORD=your_n8n_password_here
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678

# ============================================
# MongoDB (Optional - currently disabled)
# ============================================
MONGO_USER=admin
MONGO_PASSWORD=your_mongo_password_here

# ============================================
# Monitoring & Observability
# ============================================
GRAFANA_PASSWORD=your_grafana_password_here
PROMETHEUS_RETENTION=15d

# ============================================
# API Keys
# ============================================
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Qdrant Vector Database
# ============================================
QDRANT_HOST=172.28.0.2
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=rag_enterprise

# ============================================
# Redis Cache
# ============================================
REDIS_HOST=172.28.0.3
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=3600

# ============================================
# Ollama Local LLM
# ============================================
OLLAMA_HOST=172.28.0.6
OLLAMA_PORT=11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_KEEP_ALIVE=5m

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
LOG_LEVEL=DEBUG
DEBUG=true
SECRET_KEY=your_secret_key_for_jwt_here

# ============================================
# Colima Docker Resources (Optional Override)
# ============================================
COLIMA_CPU=8
COLIMA_MEMORY=16
COLIMA_DISK=100
