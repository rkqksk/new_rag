# ========================================
# RAG Enterprise - Environment Configuration
# ========================================
# Version: v5.8.0
# Last Updated: 2025-11-09
#
# 📖 Quick Setup Guide:
# 1. Copy this file: cp .env.example .env
# 2. Fill in required API keys (marked with ⚠️  REQUIRED)
# 3. Optional keys can be left as-is for testing
# 4. Never commit .env to version control!
#
# ========================================

# ========================================
# Application Settings
# ========================================
ENVIRONMENT=development                # development | staging | production
DEBUG=true                             # Enable debug mode (disable in production)

# Debug Configuration (Option B: Full Debug System)
DEBUG_ENABLED=true                     # Enable debug mode
DEBUG_LOG_REQUESTS=true                # Log request details
DEBUG_LOG_RESPONSES=false              # Log response details (can be verbose)
DEBUG_LOG_SQL=true                     # Log SQL queries
DEBUG_LOG_CACHE=true                   # Log cache operations
DEBUG_PROFILE_REQUESTS=true            # Enable performance profiling
DEBUG_SLOW_REQUEST_MS=500              # Threshold for slow request warnings (milliseconds)
DEBUG_EXPLAIN_SEARCH=true              # Enable search explanation features

# ========================================
# Database Configuration
# ========================================

# PostgreSQL Database
# 📖 Installation:
#   Docker: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:15
#   macOS: brew install postgresql@15
#   Ubuntu: sudo apt install postgresql-15
#   Windows: Download from https://www.postgresql.org/download/windows/
#
# 📖 Create Database:
#   psql -U postgres
#   CREATE DATABASE rag_enterprise;
#   CREATE USER rag_user WITH PASSWORD 'your_password';
#   GRANT ALL PRIVILEGES ON DATABASE rag_enterprise TO rag_user;
#
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_enterprise
DB_USER=postgres
DB_PASSWORD=postgres                   # ⚠️  Change in production!
DB_POOL_SIZE=20                        # Connection pool size

# Redis Cache
# 📖 Installation:
#   Docker: docker run -d -p 6379:6379 redis:7-alpine
#   macOS: brew install redis && brew services start redis
#   Ubuntu: sudo apt install redis-server
#   Windows: Use Docker or WSL
#
# 📖 Test Connection:
#   redis-cli ping  # Should return "PONG"
#
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0                             # Redis database number (0-15)

# Qdrant Vector Database
# 📖 Installation:
#   Docker: docker run -d -p 6333:6333 qdrant/qdrant:latest
#   Docker Compose: See docker-compose.yml
#
# 📖 Dashboard: http://localhost:6333/dashboard
# 📖 API Docs: https://qdrant.tech/documentation/
#
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PRODUCTS_COLLECTION=products_multimodal   # Collection name

# ========================================
# SaaS Platform Configuration (v5.0.0)
# ========================================

# JWT Authentication
# 📖 Generate Secret Key:
#   Python: python -c "import secrets; print(secrets.token_urlsafe(64))"
#   OpenSSL: openssl rand -base64 64
#   Online: https://generate-secret.vercel.app/64
#
# ⚠️  CRITICAL: Change JWT_SECRET_KEY in production!
# Use a cryptographically secure random string (64+ characters)
#
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production  # ⚠️  REQUIRED
JWT_ALGORITHM=HS256                    # HS256 (HMAC) or RS256 (RSA)
JWT_EXPIRATION_HOURS=24                # Token expiration time

# ========================================
# Stripe Billing Integration
# ========================================
# 📖 Getting Started:
#   1. Sign up: https://dashboard.stripe.com/register
#   2. Get API keys: https://dashboard.stripe.com/test/apikeys
#   3. Create products: https://dashboard.stripe.com/test/products
#   4. Set up webhooks: https://dashboard.stripe.com/test/webhooks
#
# 📖 API Keys (Test Mode):
#   - Publishable Key: Starts with 'pk_test_'
#   - Secret Key: Starts with 'sk_test_'
#   - Never expose Secret Key in frontend!
#
# 📖 Webhook Secret:
#   1. Go to: https://dashboard.stripe.com/test/webhooks
#   2. Click "Add endpoint"
#   3. URL: https://your-domain.com/api/v1/billing/webhook
#   4. Events: invoice.paid, invoice.payment_failed, customer.subscription.*
#   5. Copy webhook signing secret (starts with 'whsec_')
#
# 📖 Creating Products & Prices:
#   1. Go to: https://dashboard.stripe.com/test/products
#   2. Click "Add product"
#   3. Name: "Pro Plan", "Enterprise Plan"
#   4. Pricing: Monthly/Yearly recurring
#   5. Copy Price ID (starts with 'price_')
#
# ⚠️  REQUIRED for billing features
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key                    # ⚠️  Get from Stripe Dashboard
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key          # For frontend
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret                     # ⚠️  For webhook verification

# Stripe Price IDs (Replace with your actual Price IDs)
# 📖 How to get Price IDs:
#   1. Create products at https://dashboard.stripe.com/test/products
#   2. Click on a product
#   3. Copy the Price ID from the pricing section
#   4. Format: price_1234567890abcdefghijklmn
#
STRIPE_PRICE_PRO_MONTHLY=price_1234567890abcdef       # Pro plan monthly price
STRIPE_PRICE_PRO_YEARLY=price_1234567890abcdef        # Pro plan yearly price
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_1234567890abcdef    # Enterprise monthly
STRIPE_PRICE_ENTERPRISE_YEARLY=price_1234567890abcdef     # Enterprise yearly

# Usage Limits (per plan tier)
# Free tier
FREE_API_CALLS_LIMIT=1000              # 1K calls/month
FREE_STORAGE_LIMIT_GB=1                # 1GB storage
FREE_USERS_LIMIT=1                     # 1 user only
FREE_RATE_LIMIT_PER_MINUTE=10          # 10 requests/minute

# Pro tier
PRO_API_CALLS_LIMIT=100000             # 100K calls/month
PRO_STORAGE_LIMIT_GB=50                # 50GB storage
PRO_USERS_LIMIT=10                     # 10 users
PRO_RATE_LIMIT_PER_MINUTE=100          # 100 requests/minute

# Enterprise tier
ENTERPRISE_API_CALLS_LIMIT=-1          # Unlimited (-1)
ENTERPRISE_STORAGE_LIMIT_GB=500        # 500GB storage
ENTERPRISE_USERS_LIMIT=-1              # Unlimited users
ENTERPRISE_RATE_LIMIT_PER_MINUTE=1000  # 1000 requests/minute

# ========================================
# NexaAI SDK Integration (Optional - Fast LLM)
# ========================================
# 📖 NexaAI: On-device AI models (no API key needed for local)
#   Website: https://nexaai.com/
#   Docs: https://docs.nexaai.com/
#   GitHub: https://github.com/NexaAI/nexa-sdk
#
# 📖 Installation:
#   1. Install SDK: pip install nexaai
#   2. Start server: nexa server start
#   3. Server runs at: http://localhost:8080
#   4. No API key required for local models!
#
# 📖 Available Models:
#   - Qwen3-1.7B: Ultra-fast (< 500ms)
#   - Qwen3-VL-4B: Vision + language (< 1s)
#   - Llama3.2-3B: Balanced performance
#   - All models run locally, no cloud dependency
#
# 📖 Cloud API (Optional):
#   If using NexaAI Cloud instead of local:
#   1. Sign up: https://cloud.nexaai.com/
#   2. Get API key from dashboard
#   3. Set NEXA_API_KEY below
#
NEXA_ENABLED=true                      # Enable NexaAI (set false to use only Ollama)
NEXA_BASE_URL=http://localhost:8080/v1 # Local server URL (change if using cloud)
NEXA_API_KEY=                          # Optional: Only needed for NexaAI Cloud

# Model Router Configuration
# Controls when to use fast (NexaAI) vs quality (Ollama) models
# Based on query complexity score (0.0 - 1.0)
MODEL_ROUTER_SIMPLE_THRESHOLD=0.3      # < 0.3 = simple query → NexaAI
MODEL_ROUTER_COMPLEX_THRESHOLD=0.7     # >= 0.7 = complex query → Ollama

# NexaAI Model Selection
NEXA_MODEL_SIMPLE=Qwen3-1.7B           # Fast model (< 500ms)
NEXA_MODEL_MEDIUM=Qwen3-VL-4B          # Medium + vision (< 1s)

# ========================================
# Ollama Configuration (Quality LLM)
# ========================================
# 📖 Ollama: Run LLMs locally
#   Website: https://ollama.com/
#   Download: https://ollama.com/download
#   Models: https://ollama.com/library
#
# 📖 Installation:
#   macOS/Linux: curl -fsSL https://ollama.com/install.sh | sh
#   Windows: Download installer from https://ollama.com/download/windows
#   Docker: docker run -d -p 11434:11434 ollama/ollama
#
# 📖 Pull Models:
#   ollama pull qwen2.5:7b-instruct     # Recommended (7B params, high quality)
#   ollama pull llama3.2:3b             # Alternative (3B params, faster)
#   ollama pull mistral:7b              # Alternative (7B params)
#   ollama pull codellama:13b           # For code generation
#
# 📖 Test Connection:
#   curl http://localhost:11434/api/tags
#   Should return list of installed models
#
# 📖 Management:
#   ollama list                         # List installed models
#   ollama rm <model>                   # Remove a model
#   ollama serve                        # Start server manually
#
OLLAMA_BASE_URL=http://localhost:11434  # Ollama API endpoint
OLLAMA_MODEL=qwen2.5:7b-instruct        # Model for complex queries (~2s latency)

# ========================================
# Manufacturing Automation (Optional)
# ========================================
# 📖 Vision Inspection: YOLOv8/v10 for defect detection
#   Docs: https://docs.ultralytics.com/
#   Models: https://github.com/ultralytics/ultralytics
#
# 📖 Installation:
#   pip install ultralytics
#   pip install opencv-python
#
# 📖 Model Selection:
#   yolov8n: Nano (fastest, 3MB)
#   yolov8s: Small (balanced, 11MB)
#   yolov8m: Medium (accurate, 26MB)
#   yolov10n: Latest nano (improved accuracy)
#
VISION_MODEL=yolov8n                   # Model size: n/s/m/l/x
VISION_CONFIDENCE_THRESHOLD=0.5        # Detection confidence (0.0-1.0)
VISION_IOU_THRESHOLD=0.4               # Non-max suppression IOU

# Edge Device Configuration
# 📖 Supported Devices:
#   - NVIDIA Jetson (Xavier, Orin, Nano): TensorRT optimization
#   - Raspberry Pi 4/5: ONNX Runtime
#   - Server/Desktop: PyTorch (CPU/GPU)
#
EDGE_DEVICE_TYPE=jetson                # jetson | raspberry_pi | server
EDGE_INFERENCE_ENGINE=tensorrt         # tensorrt (Jetson) | onnx (Pi) | pytorch (server)

# Quality Control - Statistical Process Control (SPC)
SPC_ENABLED=true                       # Enable SPC charts
SPC_CONTROL_LIMIT_SIGMA=3              # Control limits (mean ± 3σ)
SPC_ALERT_EMAIL=quality@example.com    # Alert email for out-of-control

# MQTT Configuration (Edge → Server Communication)
# 📖 MQTT Brokers:
#   Mosquitto: brew install mosquitto (macOS) | apt install mosquitto (Ubuntu)
#   Docker: docker run -d -p 1883:1883 eclipse-mosquitto
#   Cloud: HiveMQ Cloud (https://www.hivemq.com/mqtt-cloud-broker/)
#
# 📖 Test Connection:
#   Subscribe: mosquitto_sub -h localhost -t test
#   Publish: mosquitto_pub -h localhost -t test -m "hello"
#
MQTT_ENABLED=true                      # Enable MQTT communication
MQTT_BROKER_HOST=localhost             # Broker address
MQTT_BROKER_PORT=1883                  # Standard MQTT port
MQTT_USERNAME=mqtt_user                # Optional authentication
MQTT_PASSWORD=mqtt_password            # Optional authentication
MQTT_TOPIC_PREFIX=manufacturing        # Topic prefix (e.g., manufacturing/vision/defects)

# ========================================
# Data Collector Configuration
# ========================================

# Web Scraping
# 📖 Scrapers Comparison:
#   - BeautifulSoup: Fast, static HTML only
#   - Playwright: Full browser, JavaScript support (recommended)
#   - Selenium: Legacy, slower but widely compatible
#
# 📖 Playwright Installation:
#   pip install playwright
#   playwright install chromium
#   playwright install-deps  # Linux only
#
WEB_SCRAPER_ENGINE=playwright          # beautifulsoup | playwright | selenium
WEB_SCRAPER_HEADLESS=true              # Run browser headless (no GUI)
WEB_SCRAPER_TIMEOUT_SECONDS=30         # Request timeout
WEB_SCRAPER_RETRY_ATTEMPTS=3           # Retry failed requests
WEB_SCRAPER_RETRY_DELAY_SECONDS=2      # Delay between retries

# User-Agent Rotation (Avoid bot detection)
WEB_SCRAPER_ROTATE_USER_AGENT=true     # Rotate user agents
WEB_SCRAPER_RESPECT_ROBOTS_TXT=true    # Respect robots.txt (recommended)

# API Polling
API_POLLER_TIMEOUT_SECONDS=30          # HTTP request timeout
API_POLLER_RETRY_ATTEMPTS=3            # Retry failed API calls
API_POLLER_RATE_LIMIT_DELAY=1          # Delay between requests (seconds)

# File Upload
FILE_UPLOAD_MAX_SIZE_MB=100            # Max file size (MB)
FILE_UPLOAD_ALLOWED_EXTENSIONS=csv,xlsx,pdf,json,xml  # Allowed file types

# Job Scheduling (APScheduler)
# 📖 APScheduler: Python job scheduling library
#   Docs: https://apscheduler.readthedocs.io/
#   Supports: Cron, interval, date-based scheduling
#
SCHEDULER_ENABLED=true                 # Enable background job scheduler
SCHEDULER_TIMEZONE=UTC                 # Timezone for scheduled jobs
SCHEDULER_MAX_INSTANCES=3              # Max concurrent jobs

# ========================================
# MinIO Object Storage (Optional)
# ========================================
# 📖 MinIO: S3-compatible object storage
#   Website: https://min.io/
#   Docs: https://docs.min.io/
#
# 📖 Installation:
#   Docker: docker run -d -p 9000:9000 -p 9001:9001 \
#           -e MINIO_ROOT_USER=minioadmin \
#           -e MINIO_ROOT_PASSWORD=minioadmin \
#           minio/minio server /data --console-address ":9001"
#   Binary: https://min.io/download
#
# 📖 Access:
#   API: http://localhost:9000
#   Console: http://localhost:9001 (login: minioadmin/minioadmin)
#
# 📖 Create Bucket:
#   mc alias set local http://localhost:9000 minioadmin minioadmin
#   mc mb local/rag-enterprise
#
MINIO_ENABLED=false                    # Enable MinIO storage
MINIO_ENDPOINT=localhost:9000          # MinIO server endpoint
MINIO_ACCESS_KEY=minioadmin            # Access key (like AWS_ACCESS_KEY_ID)
MINIO_SECRET_KEY=minioadmin            # Secret key (like AWS_SECRET_ACCESS_KEY)
MINIO_BUCKET_NAME=rag-enterprise       # Bucket name
MINIO_SECURE=false                     # Use HTTPS (true for production)

# ========================================
# API Server Configuration
# ========================================
API_HOST=0.0.0.0                       # Listen on all interfaces
API_PORT=8001                          # API server port
API_WORKERS=4                          # Uvicorn worker processes
API_RELOAD=true                        # Auto-reload on code changes (dev only!)

# CORS (Cross-Origin Resource Sharing)
# 📖 CORS: Allow frontend to access API from different origin
#   Docs: https://developer.mozilla.org/en-US/docs/Web/HTTP/CORS
#
# 📖 Development:
#   - Allow localhost:3000 (React dev server)
#   - Allow localhost:8080 (Frontend static server)
#
# 📖 Production:
#   - Set to your actual frontend domain
#   - Never use "*" in production!
#
CORS_ORIGINS=http://localhost:3000,http://localhost:8080  # Comma-separated origins
CORS_ALLOW_CREDENTIALS=true            # Allow cookies/auth headers

# ========================================
# Logging Configuration
# ========================================
# 📖 Log Levels:
#   DEBUG: Detailed debug information
#   INFO: General information messages
#   WARNING: Warning messages
#   ERROR: Error messages
#   CRITICAL: Critical errors only
#
LOG_LEVEL=INFO                         # Log level (DEBUG | INFO | WARNING | ERROR)
LOG_FORMAT=json                        # Log format (json | text)
LOG_FILE=logs/app.log                  # Log file path
LOG_MAX_BYTES=10485760                 # Max log file size (10MB)
LOG_BACKUP_COUNT=5                     # Number of backup log files

# ========================================
# Additional External APIs (Optional)
# ========================================

# OpenAI API (Optional - for GPT models)
# 📖 Getting Started:
#   1. Sign up: https://platform.openai.com/signup
#   2. Add payment method: https://platform.openai.com/account/billing
#   3. Get API key: https://platform.openai.com/api-keys
#   4. Format: sk-proj-...
#
# OPENAI_API_KEY=sk-proj-your-api-key-here

# Anthropic Claude API (Optional - for Claude models)
# 📖 Getting Started:
#   1. Sign up: https://console.anthropic.com/
#   2. Get API key: https://console.anthropic.com/settings/keys
#   3. Format: sk-ant-api03-...
#
# ANTHROPIC_API_KEY=sk-ant-api03-your-api-key-here

# Tavily Search API (Optional - AI-optimized search)
# 📖 Getting Started:
#   1. Sign up: https://tavily.com/
#   2. Free tier: 1,000 searches/month
#   3. Get API key from dashboard
#
# TAVILY_API_KEY=tvly-your-api-key-here

# Google Custom Search API (Optional)
# 📖 Getting Started:
#   1. Create project: https://console.cloud.google.com/
#   2. Enable API: https://console.cloud.google.com/apis/library/customsearch.googleapis.com
#   3. Create credentials: https://console.cloud.google.com/apis/credentials
#   4. Create Search Engine: https://programmablesearchengine.google.com/
#
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# Brave Search API (Optional - privacy-focused)
# 📖 Getting Started:
#   1. Sign up: https://brave.com/search/api/
#   2. Get API key from dashboard
#   3. Format: BSA...
#
# BRAVE_API_KEY=BSA-your-api-key-here

# SendGrid Email API (Optional - for transactional emails)
# 📖 Getting Started:
#   1. Sign up: https://signup.sendgrid.com/
#   2. Create API key: https://app.sendgrid.com/settings/api_keys
#   3. Verify sender: https://app.sendgrid.com/settings/sender_auth
#   4. Free tier: 100 emails/day
#
# SENDGRID_API_KEY=SG.your-api-key-here
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Twilio SMS API (Optional - for SMS notifications)
# 📖 Getting Started:
#   1. Sign up: https://www.twilio.com/try-twilio
#   2. Get credentials: https://console.twilio.com/
#   3. Get phone number: https://console.twilio.com/phone-numbers
#
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token-here
# TWILIO_PHONE_NUMBER=+1234567890

# Sentry Error Tracking (Optional - production recommended)
# 📖 Getting Started:
#   1. Sign up: https://sentry.io/signup/
#   2. Create project
#   3. Get DSN from project settings
#   4. Free tier: 5K errors/month
#
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ========================================
# END OF CONFIGURATION
# ========================================
#
# 📖 Quick Start:
#   1. Copy to .env: cp .env.example .env
#   2. Set required keys (marked with ⚠️)
#   3. Start services: docker-compose up -d
#   4. Run migrations: alembic upgrade head
#   5. Start API: uvicorn app.main:app --reload
#
# 📖 Documentation:
#   - Full docs: docs/
#   - API docs: http://localhost:8001/docs
#   - Quick reference: CLAUDE.md
#
# 🔐 Security Notes:
#   - Never commit .env to git
#   - Use strong passwords in production
#   - Rotate API keys regularly
#   - Enable HTTPS in production
#   - Use environment-specific configs
#

# ========================================
# Monitoring & Observability (v5.8.0+)
# ========================================

# Prometheus Metrics
# 📖 Prometheus Dashboard: http://localhost:9090
# 📖 Targets: http://localhost:9090/targets
#
PROMETHEUS_ENABLED=true                # Enable Prometheus metrics collection
PROMETHEUS_PORT=9090                   # Prometheus server port
METRICS_ENABLED=true                   # Enable /metrics endpoint

# Grafana Dashboards
# 📖 Grafana Dashboard: http://localhost:3000
# 📖 Default Login: admin / admin
#
GRAFANA_PORT=3000                      # Grafana web UI port
GRAFANA_ADMIN_USER=admin               # Grafana admin username
GRAFANA_ADMIN_PASSWORD=admin           # ⚠️  Change in production!

# Alert Configuration
ALERTING_ENABLED=true                  # Enable Prometheus alerting rules
ALERT_HIGH_ERROR_RATE_THRESHOLD=0.05   # Alert if error rate > 5%
ALERT_SLOW_RESPONSE_THRESHOLD=2000     # Alert if p95 > 2000ms

# ========================================
# Database Migrations (Alembic)
# ========================================

# Alembic Configuration
# 📖 Usage:
#   - Run migrations: alembic upgrade head
#   - Rollback: alembic downgrade -1
#   - History: alembic history
#   - Create migration: alembic revision --autogenerate -m "description"
#
ALEMBIC_SQLALCHEMY_URL=postgresql://postgres:postgres@localhost:5432/rag_enterprise

# Migration Settings
AUTO_MIGRATE_ON_STARTUP=false          # Auto-run migrations on startup (⚠️  disable in prod)
MIGRATION_TIMEOUT=60                   # Migration timeout (seconds)

# ========================================
# Caching Configuration (v5.8.0+)
# ========================================

# 3-Layer Caching System
# Layer 1: Exact Match Cache (TTL: 1h)
# Layer 2: Semantic Cache (TTL: 30min, similarity >0.95)
# Layer 3: Search Result Cache (TTL: 10min)

# Cache TTLs (Time To Live in seconds)
CACHE_EXACT_TTL=3600                   # 1 hour
CACHE_SEMANTIC_TTL=1800                # 30 minutes
CACHE_RESULT_TTL=600                   # 10 minutes

# Semantic Cache Settings
SEMANTIC_CACHE_ENABLED=true            # Enable semantic similarity caching
SEMANTIC_SIMILARITY_THRESHOLD=0.95     # Similarity threshold (0.0-1.0)
SEMANTIC_CACHE_MAX_ENTRIES=10000       # Max cached queries

# Cache Performance
CACHE_BATCH_SIZE=100                   # Batch size for cache operations
CACHE_COMPRESSION=true                 # Compress cached values (saves memory)

# ========================================
# Analytics & Behavior Tracking (v5.8.0+)
# ========================================

# Behavior Tracker Configuration
ANALYTICS_ENABLED=true                 # Enable behavior tracking
ANALYTICS_BATCH_SIZE=100               # Batch size for DB inserts
ANALYTICS_FLUSH_INTERVAL=60            # Flush interval (seconds)
ANALYTICS_BACKUP_DIR=logs/analytics    # Backup directory if DB fails

# Tracked Events
TRACK_SEARCH_LOGS=true                 # Track search queries
TRACK_CLICK_LOGS=true                  # Track product clicks
TRACK_CONVERSATION_LOGS=true           # Track chat conversations
TRACK_SAMPLE_REQUESTS=true             # Track sample requests

# Privacy Settings
ANALYTICS_ANONYMIZE_IP=false           # Anonymize IP addresses
ANALYTICS_RETENTION_DAYS=90            # Data retention period (days)

