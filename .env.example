# Application
ENVIRONMENT=development
DEBUG=true

# Debug Configuration (Option B: Full Debug System)
DEBUG_ENABLED=true                # Enable debug mode
DEBUG_LOG_REQUESTS=true           # Log request details
DEBUG_LOG_RESPONSES=false         # Log response details (can be verbose)
DEBUG_LOG_SQL=true                # Log SQL queries
DEBUG_LOG_CACHE=true              # Log cache operations
DEBUG_PROFILE_REQUESTS=true       # Enable performance profiling
DEBUG_SLOW_REQUEST_MS=500         # Threshold for slow request warnings (milliseconds)
DEBUG_EXPLAIN_SEARCH=true         # Enable search explanation features

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_enterprise
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PRODUCTS_COLLECTION=products_multimodal

# ========================================
# SaaS Platform Configuration (v5.0.0)
# ========================================

# Authentication - JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (replace with your actual price IDs from Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_1234567890abcdef
STRIPE_PRICE_PRO_YEARLY=price_1234567890abcdef
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_1234567890abcdef
STRIPE_PRICE_ENTERPRISE_YEARLY=price_1234567890abcdef

# Usage Limits (per plan tier)
# Free tier
FREE_API_CALLS_LIMIT=1000              # 1K calls/month
FREE_STORAGE_LIMIT_GB=1                # 1GB
FREE_USERS_LIMIT=1                     # 1 user
FREE_RATE_LIMIT_PER_MINUTE=10          # 10 req/min

# Pro tier
PRO_API_CALLS_LIMIT=100000             # 100K calls/month
PRO_STORAGE_LIMIT_GB=50                # 50GB
PRO_USERS_LIMIT=10                     # 10 users
PRO_RATE_LIMIT_PER_MINUTE=100          # 100 req/min

# Enterprise tier
ENTERPRISE_API_CALLS_LIMIT=-1          # Unlimited (-1)
ENTERPRISE_STORAGE_LIMIT_GB=500        # 500GB
ENTERPRISE_USERS_LIMIT=-1              # Unlimited (-1)
ENTERPRISE_RATE_LIMIT_PER_MINUTE=1000  # 1000 req/min

# ========================================
# NexaAI Integration (Optional)
# ========================================
NEXA_ENABLED=true
NEXA_BASE_URL=http://localhost:8080/v1
NEXA_API_KEY=optional_api_key_if_needed

# Model Router Configuration
MODEL_ROUTER_SIMPLE_THRESHOLD=0.3      # < 0.3 = simple (NexaAI Qwen3-1.7B)
MODEL_ROUTER_COMPLEX_THRESHOLD=0.7     # >= 0.7 = complex (Ollama qwen2.5:7b)

# NexaAI Models
NEXA_MODEL_SIMPLE=Qwen3-1.7B           # Fast model (< 500ms)
NEXA_MODEL_MEDIUM=Qwen3-VL-4B          # Medium + vision (< 1s)

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct       # Quality model (~2s)

# ========================================
# Manufacturing Automation (Optional)
# ========================================

# Vision Inspection
VISION_MODEL=yolov8n                   # yolov8n (fast) or yolov10n (accurate)
VISION_CONFIDENCE_THRESHOLD=0.5        # Defect detection confidence
VISION_IOU_THRESHOLD=0.4               # Non-max suppression IOU

# Edge Device Configuration
EDGE_DEVICE_TYPE=jetson                # jetson | raspberry_pi | server
EDGE_INFERENCE_ENGINE=tensorrt         # tensorrt (Jetson) | onnx (Pi) | pytorch (server)

# Quality Control - SPC
SPC_ENABLED=true
SPC_CONTROL_LIMIT_SIGMA=3              # Control limits (mean ± 3σ)
SPC_ALERT_EMAIL=quality@example.com    # Alert email for out-of-control conditions

# MQTT Configuration (edge → server communication)
MQTT_ENABLED=true
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_password
MQTT_TOPIC_PREFIX=manufacturing

# ========================================
# Data Collector Configuration
# ========================================

# Web Scraping
WEB_SCRAPER_ENGINE=playwright          # beautifulsoup | playwright | selenium
WEB_SCRAPER_HEADLESS=true              # Headless browser mode
WEB_SCRAPER_TIMEOUT_SECONDS=30         # Request timeout
WEB_SCRAPER_RETRY_ATTEMPTS=3           # Retry failed requests
WEB_SCRAPER_RETRY_DELAY_SECONDS=2      # Delay between retries

# User-Agent Rotation
WEB_SCRAPER_ROTATE_USER_AGENT=true
WEB_SCRAPER_RESPECT_ROBOTS_TXT=true

# API Polling
API_POLLER_TIMEOUT_SECONDS=30
API_POLLER_RETRY_ATTEMPTS=3
API_POLLER_RATE_LIMIT_DELAY=1          # Seconds between requests

# File Upload
FILE_UPLOAD_MAX_SIZE_MB=100            # Max file size for uploads
FILE_UPLOAD_ALLOWED_EXTENSIONS=csv,xlsx,pdf,json,xml

# Job Scheduling (APScheduler)
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_MAX_INSTANCES=3              # Max concurrent jobs

# MinIO Object Storage (optional)
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=rag-enterprise
MINIO_SECURE=false                     # true for HTTPS

# ========================================
# API Configuration
# ========================================
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=4
API_RELOAD=true                        # Auto-reload on code changes (dev only)

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                        # json | text
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760                 # 10MB
LOG_BACKUP_COUNT=5
