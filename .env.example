# =============================================================================
# RAG Enterprise Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
#
# IMPORTANT SECURITY NOTES:
# - NEVER commit .env files to version control
# - Use strong, randomly generated passwords in production
# - Rotate secrets regularly
# - Use secret management systems (Vault, AWS Secrets Manager) for production
#
# Validation:
# - All required variables are validated at startup
# - Production environment enforces stricter validation rules
# - See app/core/config.py for detailed validation logic
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# ENVIRONMENT: Deployment environment (development, staging, production)
# - development: Debug mode, hot-reload, verbose logging
# - staging: Production-like, Sentry enabled, moderate resources
# - production: Maximum performance, strict security, minimal logging
ENVIRONMENT=development

# LOG_LEVEL: Logging verbosity (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Recommended: DEBUG (dev), INFO (staging), WARNING (production)
LOG_LEVEL=DEBUG

# DEBUG: Enable debug mode (true/false)
# NEVER set to true in production
DEBUG=true

# APP_NAME: Application name for logging and monitoring
APP_NAME=RAG Enterprise

# APP_VERSION: Application version
APP_VERSION=2.4.0

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
# API_HOST: Server bind address (0.0.0.0 for all interfaces, 127.0.0.1 for local only)
API_HOST=0.0.0.0

# API_PORT: Server port
API_PORT=8000

# UVICORN_WORKERS: Number of Uvicorn worker processes
# Recommended: 1 (dev), 2 (staging), 4+ (production)
# Formula: (2 * CPU_CORES) + 1
UVICORN_WORKERS=1

# UVICORN_TIMEOUT_KEEP_ALIVE: Keep-alive timeout in seconds
UVICORN_TIMEOUT_KEEP_ALIVE=75

# UVICORN_BACKLOG: Maximum number of pending connections
UVICORN_BACKLOG=2048

# UVICORN_LIMIT_CONCURRENCY: Maximum concurrent requests (optional)
# UVICORN_LIMIT_CONCURRENCY=1000

# UVICORN_LIMIT_MAX_REQUESTS: Maximum requests before worker restart (optional)
# UVICORN_LIMIT_MAX_REQUESTS=10000

# -----------------------------------------------------------------------------
# PostgreSQL Database Configuration
# -----------------------------------------------------------------------------
# POSTGRES_HOST: Database host (172.28.0.4 for Docker, localhost for local)
POSTGRES_HOST=172.28.0.4

# POSTGRES_PORT: Database port
POSTGRES_PORT=5432

# POSTGRES_USER: Database username
POSTGRES_USER=postgres

# POSTGRES_PASSWORD: Database password
# REQUIRED: Use strong password in production (minimum 16 characters)
# Example: openssl rand -base64 32
POSTGRES_PASSWORD=your_secure_password_here

# POSTGRES_DB: Database name
POSTGRES_DB=rag_enterprise

# POSTGRES_POOL_SIZE: Connection pool size
# Recommended: 10 (dev), 20 (staging), 50 (production)
POSTGRES_POOL_SIZE=10

# POSTGRES_MAX_OVERFLOW: Maximum overflow connections beyond pool_size
POSTGRES_MAX_OVERFLOW=5

# POSTGRES_POOL_TIMEOUT: Connection pool timeout in seconds
POSTGRES_POOL_TIMEOUT=30

# POSTGRES_POOL_RECYCLE: Recycle connections after N seconds (-1 to disable)
POSTGRES_POOL_RECYCLE=3600

# -----------------------------------------------------------------------------
# Redis Cache Configuration
# -----------------------------------------------------------------------------
# REDIS_HOST: Redis host (172.28.0.3 for Docker, localhost for local)
REDIS_HOST=172.28.0.3

# REDIS_PORT: Redis port
REDIS_PORT=6379

# REDIS_DB: Redis database number (0-15)
REDIS_DB=0

# REDIS_PASSWORD: Redis password (optional, recommended for production)
# REDIS_PASSWORD=your_redis_password_here

# REDIS_TTL: Default cache TTL in seconds
REDIS_TTL=3600

# REDIS_POOL_MAX_CONNECTIONS: Maximum Redis pool connections
REDIS_POOL_MAX_CONNECTIONS=50

# REDIS_POOL_MIN_IDLE: Minimum idle connections in pool
REDIS_POOL_MIN_IDLE=5

# -----------------------------------------------------------------------------
# Qdrant Vector Database Configuration
# -----------------------------------------------------------------------------
# QDRANT_HOST: Qdrant host (172.28.0.2 for Docker, localhost for local)
QDRANT_HOST=172.28.0.2

# QDRANT_HTTP_PORT: Qdrant HTTP API port
QDRANT_HTTP_PORT=6333

# QDRANT_GRPC_PORT: Qdrant gRPC port (optional, for high-performance)
QDRANT_GRPC_PORT=6334

# QDRANT_TIMEOUT: Request timeout in seconds
QDRANT_TIMEOUT=30

# QDRANT_RETRY_ATTEMPTS: Number of retry attempts on failure
QDRANT_RETRY_ATTEMPTS=3

# QDRANT_API_KEY: Qdrant API key (optional, for Qdrant Cloud)
# QDRANT_API_KEY=your_qdrant_api_key_here

# QDRANT_COLLECTION: Default collection name
QDRANT_COLLECTION=rag_enterprise

# -----------------------------------------------------------------------------
# Embedding Model Configuration
# -----------------------------------------------------------------------------
# EMBEDDING_MODEL: Sentence transformer model name
# Options:
#   - sentence-transformers/all-MiniLM-L6-v2 (384 dim, fast, lightweight)
#   - sentence-transformers/all-mpnet-base-v2 (768 dim, balanced)
#   - BAAI/bge-large-en-v1.5 (1024 dim, high quality)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# EMBEDDING_DIM: Embedding vector dimension (must match model)
EMBEDDING_DIM=384

# EMBEDDING_BATCH_SIZE: Batch size for embedding generation
EMBEDDING_BATCH_SIZE=32

# EMBEDDING_DEVICE: Device for embedding model (cpu, cuda, mps)
EMBEDDING_DEVICE=cpu

# -----------------------------------------------------------------------------
# LLM Configuration (Ollama)
# -----------------------------------------------------------------------------
# OLLAMA_HOST: Ollama server host
OLLAMA_HOST=localhost

# OLLAMA_PORT: Ollama server port
OLLAMA_PORT=11434

# OLLAMA_DEFAULT_MODEL: Default Ollama model
# Options:
#   - qwen2.5:1.5b-instruct-q4_K_M (fast, 1.5B params)
#   - qwen2.5:7b-instruct-q4_K_M (balanced, 7B params)
#   - qwen2.5:14b-instruct-q4_K_M (high quality, 14B params)
OLLAMA_DEFAULT_MODEL=qwen2.5:7b-instruct-q4_K_M

# OLLAMA_TIMEOUT: Request timeout in seconds
OLLAMA_TIMEOUT=120

# OLLAMA_KEEP_ALIVE: Keep model in memory duration
OLLAMA_KEEP_ALIVE=5m

# OLLAMA_NUM_PARALLEL: Number of parallel requests
OLLAMA_NUM_PARALLEL=2

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# JWT_SECRET_KEY: Secret key for JWT token signing
# REQUIRED: Generate with: openssl rand -base64 64
# Minimum: 32 characters (development), 64 characters (production)
JWT_SECRET_KEY=dev-secret-key-change-in-production-use-openssl-rand-base64-64

# JWT_ALGORITHM: JWT signing algorithm
JWT_ALGORITHM=HS256

# JWT_ACCESS_TOKEN_EXPIRE_MINUTES: Access token expiration in minutes
# Recommended: 30 (dev), 30 (staging), 15 (production)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT_REFRESH_TOKEN_EXPIRE_DAYS: Refresh token expiration in days
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ALLOWED_ORIGINS: CORS allowed origins (comma-separated)
# Example: https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# API_KEY_HEADER: Custom API key header name (optional)
API_KEY_HEADER=X-API-Key

# -----------------------------------------------------------------------------
# External API Keys
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY: Claude API key (optional)
# Required for Claude-based features
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OPENAI_API_KEY: OpenAI API key (optional)
# Required for OpenAI-based features
# OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
# PROMETHEUS_PORT: Prometheus metrics port
PROMETHEUS_PORT=9090

# SENTRY_DSN: Sentry error tracking DSN (optional but recommended for production)
# Example: https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_DSN=

# SENTRY_ENVIRONMENT: Sentry environment tag
SENTRY_ENVIRONMENT=development

# SENTRY_TRACES_SAMPLE_RATE: Percentage of transactions to trace (0.0-1.0)
# Recommended: 0.1 (dev), 0.3 (staging), 1.0 (production)
SENTRY_TRACES_SAMPLE_RATE=0.1

# SENTRY_PROFILES_SAMPLE_RATE: Percentage of profiles to collect (0.0-1.0)
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ENABLE_METRICS: Enable Prometheus metrics (true/false)
ENABLE_METRICS=true

# METRICS_PATH: Prometheus metrics endpoint path
METRICS_PATH=/metrics

# -----------------------------------------------------------------------------
# Performance & Caching
# -----------------------------------------------------------------------------
# CACHE_TTL_DEFAULT: Default cache TTL in seconds
CACHE_TTL_DEFAULT=3600

# CACHE_TTL_EMBEDDINGS: Embedding cache TTL in seconds
CACHE_TTL_EMBEDDINGS=86400

# CACHE_TTL_SEARCH_RESULTS: Search results cache TTL in seconds
CACHE_TTL_SEARCH_RESULTS=1800

# MAX_BATCH_SIZE: Maximum batch size for bulk operations
MAX_BATCH_SIZE=100

# MAX_UPLOAD_SIZE_MB: Maximum file upload size in megabytes
MAX_UPLOAD_SIZE_MB=100

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# RATE_LIMIT_ENABLED: Enable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# RATE_LIMIT_PER_MINUTE: Maximum requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# RATE_LIMIT_BURST: Burst size for rate limiting
RATE_LIMIT_BURST=10

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# ENABLE_SWAGGER: Enable Swagger UI documentation (true/false)
# Recommended: true (dev/staging), false (production)
ENABLE_SWAGGER=true

# ENABLE_CORS: Enable CORS middleware (true/false)
ENABLE_CORS=true

# ENABLE_COMPRESSION: Enable gzip compression (true/false)
ENABLE_COMPRESSION=true

# ENABLE_PROFILING: Enable performance profiling (true/false)
# Only enable in development or debugging
ENABLE_PROFILING=false

# -----------------------------------------------------------------------------
# Search & RAG Configuration
# -----------------------------------------------------------------------------
# SEARCH_TOP_K: Default number of search results
SEARCH_TOP_K=5

# SEARCH_SCORE_THRESHOLD: Minimum similarity score threshold (0.0-1.0)
SEARCH_SCORE_THRESHOLD=0.5

# RAG_CONTEXT_WINDOW: Maximum context window for RAG queries
RAG_CONTEXT_WINDOW=2000

# RAG_MAX_TOKENS: Maximum tokens for RAG responses
RAG_MAX_TOKENS=1000

# HYBRID_SEARCH_ALPHA: Dense/sparse search weight (0.0=sparse, 1.0=dense)
HYBRID_SEARCH_ALPHA=0.5

# -----------------------------------------------------------------------------
# Document Ingestion
# -----------------------------------------------------------------------------
# CHUNK_SIZE: Document chunk size in characters
CHUNK_SIZE=500

# CHUNK_OVERLAP: Chunk overlap in characters
CHUNK_OVERLAP=50

# SUPPORTED_FORMATS: Supported document formats (comma-separated)
SUPPORTED_FORMATS=pdf,txt,docx,xlsx,csv,json

# MAX_DOCUMENT_PAGES: Maximum pages per document
MAX_DOCUMENT_PAGES=1000

# OCR_ENABLED: Enable OCR for scanned documents (true/false)
OCR_ENABLED=true

# OCR_LANGUAGE: OCR language (en, ko, ja, zh, etc.)
OCR_LANGUAGE=en

# -----------------------------------------------------------------------------
# Background Tasks & Queuing
# -----------------------------------------------------------------------------
# CELERY_BROKER_URL: Celery broker URL (optional, for async tasks)
# CELERY_BROKER_URL=redis://172.28.0.3:6379/1

# CELERY_RESULT_BACKEND: Celery result backend URL
# CELERY_RESULT_BACKEND=redis://172.28.0.3:6379/2

# CELERY_TASK_TIMEOUT: Task timeout in seconds
# CELERY_TASK_TIMEOUT=300

# -----------------------------------------------------------------------------
# Development Tools (Development Only)
# -----------------------------------------------------------------------------
# RELOAD: Enable auto-reload on code changes (true/false)
# Only for development
RELOAD=true

# MOCK_EXTERNAL_APIS: Mock external API calls (true/false)
# Useful for testing without real API keys
MOCK_EXTERNAL_APIS=false

# SQL_ECHO: Echo SQL queries to logs (true/false)
# WARNING: Very verbose, only for debugging
SQL_ECHO=false

# -----------------------------------------------------------------------------
# Colima Docker Resources (macOS Development)
# -----------------------------------------------------------------------------
# These settings are for Colima VM configuration on macOS
# Adjust based on your machine's capabilities
COLIMA_CPU=8
COLIMA_MEMORY=16
COLIMA_DISK=100

# -----------------------------------------------------------------------------
# Validation Rules Summary
# -----------------------------------------------------------------------------
# Development:
#   - JWT_SECRET_KEY: minimum 32 characters
#   - POSTGRES_PASSWORD: required
#   - Relaxed validation
#
# Staging:
#   - JWT_SECRET_KEY: minimum 64 characters
#   - SENTRY_DSN: recommended
#   - POSTGRES_PASSWORD: strong password required
#
# Production:
#   - JWT_SECRET_KEY: minimum 64 characters (ENFORCED)
#   - SENTRY_DSN: required (ENFORCED)
#   - POSTGRES_PASSWORD: strong password required (ENFORCED)
#   - ALLOWED_ORIGINS: must be HTTPS in production
#   - DEBUG: must be false
#   - LOG_LEVEL: must be WARNING or ERROR
# -----------------------------------------------------------------------------
