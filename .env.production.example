# Production Environment Configuration
# Copy to .env.production and fill in actual values

# Application
NODE_ENV=production
PYTHON_ENV=production

# API
API_URL=https://api.rag-enterprise.com
NEXT_PUBLIC_API_URL=https://api.rag-enterprise.com

# Database
DATABASE_URL=postgresql://user:password@postgres:5432/rag_production
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=
POSTGRES_DB=rag_production

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Authentication
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# OAuth (Keycloak)
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Secrets (Vault)
VAULT_ADDR=
VAULT_TOKEN=

# LLM APIs
CLAUDE_API_KEY=
OPENAI_API_KEY=
NEXA_API_KEY=

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENDPOINT=
JAEGER_ENDPOINT=

# Storage
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@rag-enterprise.com

# Stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# CORS
CORS_ORIGINS=https://rag-enterprise.com,https://www.rag-enterprise.com

# Feature Flags
ENABLE_REALTIME=true
ENABLE_ANALYTICS=true
ENABLE_BILLING=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
