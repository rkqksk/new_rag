{
  "name": "freemold_crawler",
  "version": "1.0.0",
  "description": "Freemold.net 제품 상세 크롤러 - 스마트 로그인 (자동/수동)",
  "author": "RAG Enterprise Team",
  "created": "2025-10-28",
  "type": "crawler",
  "capabilities": [
    "Smart login (.env auto → manual fallback)",
    "Product detail extraction",
    "Progress tracking (resumable)",
    "Alert handling",
    "Session persistence",
    "Error recovery"
  ],
  "requirements": {
    "python": ">=3.11",
    "packages": [
      "selenium>=4.0.0",
      "python-dotenv>=1.0.0"
    ],
    "system": [
      "Chrome/Chromium browser",
      "ChromeDriver"
    ],
    "credentials": {
      "file": "/.env",
      "variables": ["FREEMOLD_USERNAME", "FREEMOLD_PASSWORD"]
    }
  },
  "configuration": {
    "delay_min": 5.0,
    "delay_max": 7.0,
    "headless": false,
    "output_dir": "data/freemold/crawled_v2"
  },
  "login_strategy": {
    "primary": "automatic (.env credentials)",
    "fallback": "manual login with browser window",
    "notes": "Headless mode not supported - requires visible browser for session persistence"
  },
  "usage": {
    "command": "python3 crawler.py",
    "examples": [
      "python3 crawler.py  # Full crawling with smart login"
    ]
  },
  "output": {
    "format": "JSON",
    "structure": {
      "products": "data/freemold/crawled_v2/*.json",
      "progress": "data/freemold/crawled_v2/crawl_progress_selenium.json"
    }
  },
  "features": {
    "resume": true,
    "parallel": false,
    "auth_required": true,
    "rate_limited": true,
    "smart_login": true
  },
  "stats": {
    "target_products": "21,592",
    "estimated_time": "26 hours",
    "success_rate": "95%+"
  }
}
