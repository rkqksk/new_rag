# Staging Environment Configuration

NODE_ENV=staging
PYTHON_ENV=staging

# API
API_URL=https://staging-api.rag-enterprise.com
NEXT_PUBLIC_API_URL=https://staging-api.rag-enterprise.com

# Database
DATABASE_URL=postgresql://user:password@postgres:5432/rag_staging

# Redis
REDIS_URL=redis://redis:6379

# Feature Flags
ENABLE_REALTIME=true
ENABLE_ANALYTICS=true
ENABLE_BILLING=false

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty
