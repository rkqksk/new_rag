{
  "name": "monitoring-agent",
  "version": "1.0.0",
  "description": "Monitoring and performance agent - metrics, logs, alerts, profiling",
  "capabilities": [
    "performance-monitoring",
    "log-analysis",
    "metrics-collection",
    "alerting",
    "profiling"
  ],
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/user/rag-enterprise"
      ],
      "description": "File operations for logs and metrics",
      "enabled": true,
      "priority": "high",
      "transport": "stdio"
    }
  },
  "tools": [
    "prometheus",
    "grafana",
    "python-profiler",
    "docker-stats"
  ],
  "config": {
    "metrics_interval": 60,
    "log_retention_days": 30,
    "alert_threshold": 0.9,
    "profiling_enabled": true
  },
  "metadata": {
    "created": "2025-11-08",
    "updated": "2025-11-08",
    "status": "production-ready",
    "cost": "$0/month (100% open-source)",
    "monitoring_stack": "Prometheus + Grafana"
  }
}
