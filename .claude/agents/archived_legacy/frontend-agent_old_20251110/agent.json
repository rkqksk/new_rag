{
  "name": "frontend-agent",
  "version": "1.0.0",
  "description": "Frontend development agent with React, Tailwind, shadcn/ui, and live browser debugging",
  "capabilities": [
    "react-development",
    "tailwind-styling",
    "ui-components",
    "live-debugging",
    "responsive-design"
  ],
  "mcpServers": {
    "shadcn-ui": {
      "command": "npx",
      "args": [
        "-y",
        "@ymadd/shadcn-ui-mcp-server"
      ],
      "description": "shadcn/ui component library (50+ React components with Tailwind)",
      "enabled": true,
      "priority": "high",
      "transport": "stdio"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "description": "Live browser debugging (DOM, CSS, Console, Performance, Network)",
      "enabled": true,
      "priority": "high",
      "note": "Requires Node.js \u226522 and Chrome browser",
      "transport": "stdio"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/oypnus/Project/new_rag "
      ],
      "description": "File operations for frontend code",
      "enabled": true,
      "priority": "high",
      "transport": "stdio"
    }
  },
  "config": {
    "default_framework": "react",
    "styling": "tailwind",
    "component_library": "shadcn-ui",
    "browser": "chrome"
  },
  "metadata": {
    "created": "2025-11-08",
    "updated": "2025-11-08",
    "status": "production-ready",
    "cost": "$0/month (all MCPs are free)"
  }
}
