{
  "name": "testing-agent",
  "version": "1.0.0",
  "description": "Automated testing agent - unit tests, integration tests, coverage analysis",
  "capabilities": [
    "unit-testing",
    "integration-testing",
    "coverage-analysis",
    "test-generation",
    "test-optimization"
  ],
  "mcpServers": {
    "testsprite": {
      "command": "npx",
      "args": [
        "-y",
        "@testsprite/testsprite-mcp"
      ],
      "env": {
        "TESTSPRITE_API_KEY": "${TESTSPRITE_API_KEY}"
      },
      "description": "AI-powered automatic testing, debugging, and code quality validation",
      "enabled": true,
      "priority": "critical",
      "note": "Improves AI code quality from 42% to 93% pass rate. Get free API key at https://testsprite.com",
      "transport": "stdio",
      "features": [
        "automatic-test-generation",
        "smart-test-plans",
        "parallel-test-execution",
        "failure-diagnosis",
        "structured-test-reports",
        "cloud-infrastructure"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/oypnus/Project/new_rag "
      ],
      "description": "File operations for test files",
      "enabled": true,
      "priority": "high",
      "transport": "stdio"
    }
  },
  "tools": [
    "pytest",
    "pytest-cov",
    "pytest-asyncio",
    "pytest-mock"
  ],
  "config": {
    "test_framework": "pytest",
    "coverage_threshold": 95,
    "parallel_tests": true,
    "auto_generate": false
  },
  "metadata": {
    "created": "2025-11-08",
    "updated": "2025-11-09",
    "status": "production-ready",
    "cost": "$0/month (100% open-source + TestSprite free tier)",
    "current_coverage": "95%+ target",
    "enhancements": [
      "Added TestSprite MCP for intelligent test automation",
      "Automatic test case generation from PRD",
      "Cloud-based parallel test execution",
      "AI-powered failure diagnosis"
    ]
  }
}
