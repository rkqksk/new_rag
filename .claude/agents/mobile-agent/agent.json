{
  "name": "mobile-agent",
  "version": "1.0.0",
  "description": "React Native and Expo mobile development specialist",
  "type": "mobile",
  "tools": [
    "Read",
    "Write",
    "Edit",
    "Bash",
    "Grep",
    "Glob"
  ],
  "mcpServers": {
    "react-native-mcp": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "react-native-mcp"],
      "description": "React Native development tools",
      "enabled": true,
      "priority": 1
    },
    "expo-mcp": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "expo-mcp"],
      "description": "Expo SDK and EAS Build tools",
      "enabled": true,
      "priority": 2
    }
  },
  "skills": [
    "mobile-ui",
    "native-features",
    "platform-bridge"
  ],
  "specialization": {
    "platforms": ["ios", "android"],
    "frameworks": ["react-native", "expo"],
    "features": [
      "biometric-auth",
      "camera-integration",
      "push-notifications",
      "offline-first",
      "deep-linking"
    ]
  },
  "workflow": {
    "buildCommand": "eas build",
    "testCommand": "jest",
    "lintCommand": "eslint src/",
    "formatCommand": "prettier --write \"**/*.{ts,tsx}\""
  },
  "configuration": {
    "tokenReduction": true,
    "progressiveLoading": true,
    "maxTokensPerResponse": 4000
  }
}