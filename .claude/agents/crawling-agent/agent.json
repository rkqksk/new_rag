{
  "name": "crawling-agent",
  "version": "1.0.0",
  "description": "Dedicated web crawling and data acquisition agent with integrated MCP servers",
  "capabilities": [
    "web-crawling",
    "authentication",
    "anti-detection",
    "data-extraction",
    "session-management"
  ],
  "mcpServers": {
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "description": "Browser automation for dynamic content",
      "enabled": true,
      "priority": "high"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/test"],
      "description": "Advanced browser automation with anti-detection",
      "enabled": true,
      "priority": "high"
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "description": "Fast HTTP requests for static content",
      "enabled": true,
      "priority": "high"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "description": "Live browser debugging and inspection",
      "enabled": true,
      "priority": "medium"
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "@tavily/mcp-server"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "description": "AI-optimized web search and content extraction",
      "enabled": false,
      "priority": "low",
      "note": "Requires API key"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/user/rag-enterprise"],
      "description": "File operations for crawled data storage",
      "enabled": true,
      "priority": "high"
    }
  },
  "tools": [
    "app.services.crawling.StaticCrawler",
    "app.services.crawling.DynamicCrawler",
    "app.services.crawling.MultiStrategyCrawler",
    "app.services.crawling.ManualAuthHandler",
    "app.services.crawling.RobotsHandler",
    "app.services.crawling.AntiDetectionManager",
    "app.services.crawling.SessionManager"
  ],
  "config": {
    "max_concurrent_requests": 5,
    "default_timeout": 30,
    "rate_limit": {
      "max_requests": 10,
      "time_window": 60
    },
    "anti_detection": {
      "enabled": true,
      "rotate_user_agent": true,
      "min_delay": 2.0,
      "max_delay": 5.0
    },
    "robots_policy": "respect",
    "session_storage": "/home/user/.rag-enterprise/sessions"
  },
  "metadata": {
    "created": "2025-11-08",
    "updated": "2025-11-08",
    "status": "production-ready",
    "test_coverage": "27 tests passing"
  }
}
