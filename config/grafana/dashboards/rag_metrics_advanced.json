{
  "dashboard": {
    "title": "RAG - Advanced Retrieval Metrics",
    "tags": ["rag", "search", "retrieval", "ai"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Average Retrieval Time",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT AVG(retrieval_time_ms) as value FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "decimals": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 500, "color": "yellow" },
                { "value": 1000, "color": "red" }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "id": 2,
        "title": "Total Queries (Last Hour)",
        "type": "stat",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT COUNT(*) as value FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "blue" }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 3,
        "title": "Average Relevance Score",
        "type": "gauge",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT AVG(avg_score) * 100 as value FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 70, "color": "yellow" },
                { "value": 90, "color": "green" }
              ]
            }
          }
        },
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 4,
        "title": "Average Results per Query",
        "type": "stat",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT AVG(num_results) as value FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 1,
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "blue" }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Query Type Distribution",
        "type": "piechart",
        "gridPos": { "x": 0, "y": 4, "w": 8, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT query_type, COUNT(*) as value FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '24 hours' GROUP BY query_type",
            "refId": "A",
            "format": "table"
          }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
          "pieType": "donut"
        },
        "fieldConfig": {
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "factual" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
            },
            {
              "matcher": { "id": "byName", "options": "analytical" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
            },
            {
              "matcher": { "id": "byName", "options": "comparative" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
            },
            {
              "matcher": { "id": "byName", "options": "procedural" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
            },
            {
              "matcher": { "id": "byName", "options": "troubleshooting" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
            }
          ]
        }
      },
      {
        "id": 6,
        "title": "Retrieval Strategy Distribution",
        "type": "piechart",
        "gridPos": { "x": 8, "y": 4, "w": 8, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT strategy_used, COUNT(*) as value FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '24 hours' GROUP BY strategy_used",
            "refId": "A",
            "format": "table"
          }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
          "pieType": "donut"
        }
      },
      {
        "id": 7,
        "title": "Context Compression Ratio",
        "type": "gauge",
        "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT AVG(context_compression_ratio) as value FROM rag_metrics WHERE context_compression_ratio IS NOT NULL AND timestamp >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "decimals": 2,
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 0.5, "color": "yellow" },
                { "value": 0.8, "color": "red" }
              ]
            },
            "mappings": [
              {
                "type": "range",
                "options": {
                  "from": 0,
                  "to": 0.3,
                  "result": { "text": "Excellent (5x compression)" }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": 0.3,
                  "to": 0.5,
                  "result": { "text": "Good (2-3x compression)" }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": 0.5,
                  "to": 1,
                  "result": { "text": "Minimal compression" }
                }
              }
            ]
          }
        }
      },
      {
        "id": 8,
        "title": "Retrieval Time Trend",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT time_bucket('5 minutes', timestamp) as time, AVG(retrieval_time_ms) as avg_time, MIN(retrieval_time_ms) as min_time, MAX(retrieval_time_ms) as max_time FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '24 hours' GROUP BY time ORDER BY time",
            "refId": "A",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": { "drawStyle": "line", "fillOpacity": 10 }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "avg_time" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
            },
            {
              "matcher": { "id": "byName", "options": "min_time" },
              "properties": [
                { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } },
                { "id": "custom.fillOpacity", "value": 0 }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "max_time" },
              "properties": [
                { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
                { "id": "custom.fillOpacity", "value": 0 }
              ]
            }
          ]
        }
      },
      {
        "id": 9,
        "title": "Relevance Score Trend",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT time_bucket('5 minutes', timestamp) as time, AVG(avg_score) as relevance_score FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '24 hours' GROUP BY time ORDER BY time",
            "refId": "A",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "custom": { "drawStyle": "line", "fillOpacity": 20 }
          }
        }
      },
      {
        "id": 10,
        "title": "Query Volume by Type (Last 24h)",
        "type": "barchart",
        "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT query_type, COUNT(*) as count FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '24 hours' GROUP BY query_type ORDER BY count DESC",
            "refId": "A",
            "format": "table"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "xField": "query_type"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" }
          }
        }
      },
      {
        "id": 11,
        "title": "Strategy Performance Comparison",
        "type": "table",
        "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT strategy_used as strategy, COUNT(*) as queries, AVG(retrieval_time_ms) as avg_time_ms, AVG(avg_score) * 100 as avg_relevance_pct, AVG(num_results) as avg_results FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '24 hours' GROUP BY strategy_used ORDER BY queries DESC",
            "refId": "A",
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "strategy": "Strategy",
                "queries": "Queries",
                "avg_time_ms": "Avg Time (ms)",
                "avg_relevance_pct": "Avg Relevance (%)",
                "avg_results": "Avg Results"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Avg Time (ms)" },
              "properties": [
                { "id": "unit", "value": "ms" },
                { "id": "decimals", "value": 0 },
                { "id": "custom.cellOptions", "value": { "type": "color-background" } },
                { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": 0, "color": "green" },
                    { "value": 500, "color": "yellow" },
                    { "value": 1000, "color": "red" }
                  ]
                }}
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Avg Relevance (%)" },
              "properties": [
                { "id": "unit", "value": "percent" },
                { "id": "decimals", "value": 1 },
                { "id": "custom.cellOptions", "value": { "type": "color-background" } },
                { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": 0, "color": "red" },
                    { "value": 70, "color": "yellow" },
                    { "value": 90, "color": "green" }
                  ]
                }}
              ]
            }
          ]
        }
      },
      {
        "id": 12,
        "title": "Queries per Minute",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 28, "w": 24, "h": 6 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT time_bucket('1 minute', timestamp) as time, COUNT(*) as queries_per_min FROM rag_metrics WHERE timestamp >= NOW() - INTERVAL '1 hour' GROUP BY time ORDER BY time",
            "refId": "A",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "bars", "fillOpacity": 50 }
          }
        }
      }
    ]
  }
}
