{
  "dashboard": {
    "title": "Manufacturing Quality (LORA Vision)",
    "tags": ["edge-computing", "manufacturing", "quality"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Quality Overview (Last Hour)",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT COUNT(*) * 100.0 / NULLIF((SELECT COUNT(*) FROM quality_inspections WHERE time >= NOW() - INTERVAL '1 hour'), 0) as value FROM quality_inspections WHERE inspection_result = 'pass' AND time >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 90, "color": "yellow" },
                { "value": 95, "color": "green" }
              ]
            }
          }
        },
        "options": {
          "graphMode": "area",
          "colorMode": "background",
          "text": { "titleSize": 20, "valueSize": 40 }
        }
      },
      {
        "id": 2,
        "title": "Total Inspections (Last Hour)",
        "type": "stat",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT COUNT(*) as value FROM quality_inspections WHERE time >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "blue" }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Avg Cycle Time",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT AVG(cycle_time_ms) as value FROM quality_inspections WHERE time >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "decimals": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 50, "color": "yellow" },
                { "value": 100, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Avg Confidence",
        "type": "stat",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT AVG(confidence) * 100 as value FROM quality_inspections WHERE time >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 70, "color": "yellow" },
                { "value": 85, "color": "green" }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Pass/Fail Rate (Hourly)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT bucket, pass_count * 100.0 / total_inspections as pass_rate, reject_count * 100.0 / total_inspections as reject_rate FROM quality_metrics_hourly WHERE bucket >= NOW() - INTERVAL '24 hours' ORDER BY bucket",
            "refId": "A",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": { "drawStyle": "bars", "fillOpacity": 70 }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "pass_rate" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
            },
            {
              "matcher": { "id": "byName", "options": "reject_rate" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
            }
          ]
        }
      },
      {
        "id": 6,
        "title": "Cycle Time Trend",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT bucket, product_type, avg_cycle_time FROM quality_metrics_hourly WHERE bucket >= NOW() - INTERVAL '24 hours' ORDER BY bucket",
            "refId": "A",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": { "drawStyle": "line", "fillOpacity": 10 }
          }
        }
      },
      {
        "id": 7,
        "title": "Product Type Distribution",
        "type": "piechart",
        "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT product_type, COUNT(*) as value FROM quality_inspections WHERE time >= NOW() - INTERVAL '24 hours' GROUP BY product_type",
            "refId": "A"
          }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "right" },
          "pieType": "donut"
        }
      },
      {
        "id": 8,
        "title": "Defect Types",
        "type": "table",
        "gridPos": { "x": 8, "y": 12, "w": 16, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT product_type, jsonb_array_elements_text(defects) as defect_type, COUNT(*) as occurrences FROM quality_inspections WHERE defects IS NOT NULL AND jsonb_array_length(defects) > 0 AND time >= NOW() - INTERVAL '24 hours' GROUP BY product_type, defect_type ORDER BY occurrences DESC LIMIT 20",
            "refId": "A",
            "format": "table"
          }
        ]
      },
      {
        "id": 9,
        "title": "Inspections Per Minute (Realtime)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT time_bucket('1 minute', time) as bucket, COUNT(*) as inspections_per_minute FROM quality_inspections WHERE time >= NOW() - INTERVAL '1 hour' GROUP BY bucket ORDER BY bucket",
            "refId": "A",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "bars", "fillOpacity": 50 }
          }
        }
      }
    ]
  }
}
