{
  "dashboard": {
    "title": "Distributed Web Crawler - Monitoring",
    "tags": ["crawler", "web-scraping", "data-collection"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Total Crawled Pages",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT COUNT(*) as value FROM crawl_results WHERE status = 'completed'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "blue" },
                { "value": 100, "color": "green" },
                { "value": 1000, "color": "yellow" }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "id": 2,
        "title": "Active Workers",
        "type": "stat",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT COUNT(DISTINCT worker_id) as value FROM crawler_workers WHERE last_heartbeat >= NOW() - INTERVAL '30 seconds'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 1, "color": "yellow" },
                { "value": 5, "color": "green" }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 3,
        "title": "Pages per Second",
        "type": "gauge",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT COUNT(*) / 60.0 as value FROM crawl_results WHERE crawled_at >= NOW() - INTERVAL '1 minute' AND status = 'completed'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 1,
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 1, "color": "yellow" },
                { "value": 10, "color": "green" }
              ]
            }
          }
        },
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "gauge",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT COUNT(CASE WHEN status = 'failed' THEN 1 END) * 100.0 / NULLIF(COUNT(*), 0) as value FROM crawl_results WHERE crawled_at >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 5, "color": "yellow" },
                { "value": 10, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Crawl Status Distribution",
        "type": "piechart",
        "gridPos": { "x": 0, "y": 4, "w": 8, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT status, COUNT(*) as value FROM crawl_results WHERE crawled_at >= NOW() - INTERVAL '24 hours' GROUP BY status",
            "refId": "A",
            "format": "table"
          }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
          "pieType": "donut"
        },
        "fieldConfig": {
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "completed" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
            },
            {
              "matcher": { "id": "byName", "options": "failed" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
            },
            {
              "matcher": { "id": "byName", "options": "in_progress" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
            },
            {
              "matcher": { "id": "byName", "options": "rate_limited" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
            }
          ]
        }
      },
      {
        "id": 6,
        "title": "Crawling Rate (Pages/min)",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 4, "w": 16, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT time_bucket('1 minute', crawled_at) as time, COUNT(*) as pages_per_minute FROM crawl_results WHERE crawled_at >= NOW() - INTERVAL '1 hour' AND status = 'completed' GROUP BY time ORDER BY time",
            "refId": "A",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "bars", "fillOpacity": 60 },
            "color": { "mode": "palette-classic" }
          }
        }
      },
      {
        "id": 7,
        "title": "Average Response Time",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT time_bucket('5 minutes', crawled_at) as time, AVG(duration_ms) as avg_duration, MIN(duration_ms) as min_duration, MAX(duration_ms) as max_duration FROM crawl_results WHERE crawled_at >= NOW() - INTERVAL '24 hours' AND status = 'completed' GROUP BY time ORDER BY time",
            "refId": "A",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": { "drawStyle": "line", "fillOpacity": 10 }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "avg_duration" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
            },
            {
              "matcher": { "id": "byName", "options": "min_duration" },
              "properties": [
                { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } },
                { "id": "custom.fillOpacity", "value": 0 }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "max_duration" },
              "properties": [
                { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
                { "id": "custom.fillOpacity", "value": 0 }
              ]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Queue Size (Pending Jobs)",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT time, queue_size FROM crawler_stats WHERE time >= NOW() - INTERVAL '1 hour' ORDER BY time",
            "refId": "A",
            "format": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "line", "fillOpacity": 20 },
            "color": { "mode": "palette-classic" }
          }
        }
      },
      {
        "id": 9,
        "title": "Top 10 Crawled Domains",
        "type": "barchart",
        "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT split_part(url, '/', 3) as domain, COUNT(*) as count FROM crawl_results WHERE crawled_at >= NOW() - INTERVAL '24 hours' AND status = 'completed' GROUP BY domain ORDER BY count DESC LIMIT 10",
            "refId": "A",
            "format": "table"
          }
        ],
        "options": {
          "orientation": "horizontal"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" }
          }
        }
      },
      {
        "id": 10,
        "title": "Recent Failed Crawls",
        "type": "table",
        "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT crawled_at as time, url, error, duration_ms FROM crawl_results WHERE status = 'failed' AND crawled_at >= NOW() - INTERVAL '1 hour' ORDER BY crawled_at DESC LIMIT 50",
            "refId": "A",
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "time": "Time",
                "url": "URL",
                "error": "Error Message",
                "duration_ms": "Duration (ms)"
              }
            }
          }
        ]
      },
      {
        "id": 11,
        "title": "Worker Performance",
        "type": "table",
        "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT worker_id, COUNT(*) as total_jobs, COUNT(CASE WHEN status = 'completed' THEN 1 END) as completed, COUNT(CASE WHEN status = 'failed' THEN 1 END) as failed, AVG(duration_ms) as avg_duration FROM crawl_results WHERE crawled_at >= NOW() - INTERVAL '1 hour' GROUP BY worker_id ORDER BY total_jobs DESC",
            "refId": "A",
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "worker_id": "Worker ID",
                "total_jobs": "Total Jobs",
                "completed": "Completed",
                "failed": "Failed",
                "avg_duration": "Avg Duration (ms)"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Failed" },
              "properties": [
                { "id": "custom.cellOptions", "value": { "type": "color-background" } },
                { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": 0, "color": "green" },
                    { "value": 1, "color": "yellow" },
                    { "value": 10, "color": "red" }
                  ]
                }}
              ]
            }
          ]
        }
      },
      {
        "id": 12,
        "title": "Content Size Distribution",
        "type": "histogram",
        "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT length(content) as content_size FROM crawl_results WHERE status = 'completed' AND crawled_at >= NOW() - INTERVAL '24 hours' AND content IS NOT NULL",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": { "fillOpacity": 70 }
          }
        }
      },
      {
        "id": 13,
        "title": "Links Extracted per Page",
        "type": "stat",
        "gridPos": { "x": 0, "y": 36, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT AVG(jsonb_array_length(links)) as value FROM crawl_results WHERE status = 'completed' AND crawled_at >= NOW() - INTERVAL '24 hours' AND links IS NOT NULL",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 1,
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "blue" }
              ]
            }
          }
        }
      },
      {
        "id": 14,
        "title": "Success Rate (Last Hour)",
        "type": "stat",
        "gridPos": { "x": 6, "y": 36, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT COUNT(CASE WHEN status = 'completed' THEN 1 END) * 100.0 / NULLIF(COUNT(*), 0) as value FROM crawl_results WHERE crawled_at >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 90, "color": "yellow" },
                { "value": 98, "color": "green" }
              ]
            }
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 15,
        "title": "Total Data Collected",
        "type": "stat",
        "gridPos": { "x": 12, "y": 36, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT SUM(length(content)) as value FROM crawl_results WHERE status = 'completed' AND content IS NOT NULL",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decbytes",
            "decimals": 2,
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "blue" }
              ]
            }
          }
        }
      },
      {
        "id": 16,
        "title": "Retry Rate",
        "type": "stat",
        "gridPos": { "x": 18, "y": 36, "w": 6, "h": 4 },
        "targets": [
          {
            "datasource": { "type": "postgres", "uid": "TimescaleDB" },
            "rawSql": "SELECT COUNT(CASE WHEN retry_count > 0 THEN 1 END) * 100.0 / NULLIF(COUNT(*), 0) as value FROM crawl_results WHERE crawled_at >= NOW() - INTERVAL '1 hour'",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 5, "color": "yellow" },
                { "value": 15, "color": "orange" }
              ]
            }
          }
        }
      }
    ]
  }
}
