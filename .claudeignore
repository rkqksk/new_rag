# ============================================
models/
checkpoints/
finetuning/models/
*.pt
*.pth
*.ckpt
*.safetensors
*.bin

# ============================================
# Logs & Reports
# ============================================
*.log
logs/
htmlcov/
.coverage
*.out

# ============================================
# Python Cache
# ============================================
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ============================================
# Virtual Environments
# ============================================
.venv/
venv/
ENV/
env/

# ============================================
# Node Modules
# ============================================
node_modules/

# ============================================
