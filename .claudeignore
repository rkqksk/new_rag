# ============================================
models/
checkpoints/
finetuning/models/
*.pt
*.pth
*.ckpt
*.safetensors
*.bin

# ============================================
# Logs & Reports
# ============================================
*.log
logs/
htmlcov/
.coverage
*.out

# ============================================
# Python Cache
# ============================================
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ============================================
# Virtual Environments
# ============================================
.venv/
venv/
ENV/
env/

# ============================================
# Node Modules
# ============================================
node_modules/

# ============================================
# Archives & Backups
# ============================================
archives/
.backups/
*.backup
*.bak
*.old

# ============================================
# Temporary Files
# ============================================
temp/
tmp/
*.tmp
.DS_Store

# ============================================
# Claude Internal
# ============================================
.claude/agents/_archived/
.claude/debug/
.claude/logs/
.claude/shell-snapshots/
.claude/file-history/

# ============================================
